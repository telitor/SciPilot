# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional Generic LLM
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Paper Reading Agent
XF_AGENT_APP_ID=your_xunfei_app_id
XF_AGENT_API_KEY=your_xunfei_api_key
XF_AGENT_API_SECRET=your_xunfei_api_secret
XF_AGENT_ASSISTANT_ID=your_paper_reading_assistant_id
XF_AGENT_WS_HOST=spark-openapi.cn-huabei-1.xf-yun.com
XF_AGENT_WS_PATH=/v1/assistants/{assistant_id}

# Problem Decomposition Agent
PROBLEM_DECOMPOSITION_APP_ID=your_problem_decomposition_app_id
PROBLEM_DECOMPOSITION_API_KEY=your_problem_decomposition_api_key
PROBLEM_DECOMPOSITION_API_SECRET=your_problem_decomposition_api_secret
PROBLEM_DECOMPOSITION_WS_URL=your_problem_decomposition_interface_url

# Result Interpretation Agent
RESULT_INTERPRETATION_APP_ID=your_result_interpretation_app_id
RESULT_INTERPRETATION_API_KEY=your_result_interpretation_api_key
RESULT_INTERPRETATION_API_SECRET=your_result_interpretation_api_secret
RESULT_INTERPRETATION_WS_URL=your_result_interpretation_interface_url

# Code Reproduction Agent
CODE_REPRODUCTION_APP_ID=your_code_reproduction_app_id
CODE_REPRODUCTION_API_KEY=your_code_reproduction_api_key
CODE_REPRODUCTION_API_SECRET=your_code_reproduction_api_secret
CODE_REPRODUCTION_WS_URL=your_code_reproduction_interface_url

# Xunfei Chat Parameters
XF_AGENT_DOMAIN=generalv3
XF_AGENT_TEMPERATURE=0.5
XF_AGENT_TOP_K=4
XF_AGENT_MAX_TOKENS=2028
